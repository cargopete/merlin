# Copy to .env and fill in. All keys are optional except YTM for playlist writes.

# --- YouTube Music (OAuth) ---
# Create a Google Cloud OAuth client of type "TVs and Limited Input devices".
MERLIN_YTM_CLIENT_ID=
MERLIN_YTM_CLIENT_SECRET=
# MERLIN_YTM_LANGUAGE=en

# --- MusicBrainz (Phase 1+) ---
# Put a real contact email — MB blocks anonymous/abusive User-Agents.
MERLIN_CONTACT_EMAIL=you@example.com

# --- Last.fm (Phase 2+) ---
MERLIN_LASTFM_API_KEY=
MERLIN_LASTFM_API_SECRET=
MERLIN_LASTFM_USER=

# --- ListenBrainz (Phase 1+) ---
MERLIN_LISTENBRAINZ_TOKEN=
MERLIN_LISTENBRAINZ_USER=

# --- Service / storage (optional overrides) ---
# MERLIN_HOST=127.0.0.1
# MERLIN_PORT=7654
# MERLIN_DATA_DIR=~/.local/share/merlin

# --- Fusion weights (Phase 2/3, optional) ---
# MERLIN_W_AUDIO=0.4
# MERLIN_W_CF=0.5
# MERLIN_W_POP=0.1
# MERLIN_MMR_LAMBDA=0.7
# MERLIN_PER_ARTIST_CAP=2
